# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# TOR Control Port authentication password / API key.
# Must be at least 8 characters; no control chars, quotes, or backslash.
TOR_API_KEY=your-api-key-here

# TOR control-port address (default: 127.0.0.1)
TOR_CONTROL_HOST=127.0.0.1

# TOR control-port number (default: 9051)
TOR_CONTROL_PORT=9051
